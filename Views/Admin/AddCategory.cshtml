@{
    ViewData["Title"] = "Add Category";

}

    @section Styles{
    <link rel="stylesheet" href="~/css/admin/add-category.css">
    }

<section class="form-section">
    <div class="form-card">
        
        <div class="form-card-header">
            <h2>Add New Category</h2>
            <p>Create a new food category for your restaurant menu</p>
        </div>

        <form action="" method="POST" enctype="multipart/form-data" class="admin-form">
            
            <div class="form-group">
                <label for="category-name">Category Name</label>
                <input type="text" id="category-name" name="category_name" placeholder="e.g. Desserts, Burgers, Pizza" required>
            </div>

            <div class="form-group">
                <label for="category-image">Category Image / Icon</label>
                <div class="file-input-wrapper">
                    <input type="file" id="category-image" name="category_image" accept="image/*" required>
                </div>
            </div>

            <div class="form-actions">
                <a href="/Home/ManageMenu" class="form-btn cancel-btn">Cancel</a>
                <button type="submit" class="form-btn submit-btn">Save Category</button>
            </div>

        </form>

    </div>
</section>
