@model List<UserModel>
@{
    ViewData["Title"] = "Manage Users";

}

    @section Styles{
    <link rel="stylesheet" href="~/css/admin/manage-users.css">
    }
<section class="dashboard-section">
    <div class="dashboard-container">
        
        <div class="dashboard-header">
            <div>
                <h2>Manage Users</h2>
                <p>View, control, and manage all registered user accounts, passwords, and system roles</p>
            </div>
        </div>
        @if (TempData["message"] != null)
        {
            <div class="successful-operation">

                @TempData["message"]


            </div>



        }

        <div class="table-wrapper">
            <table class="users-table">
                <thead>
                    <tr>
                        <th>User ID</th>
                        <th>Full Name</th>
                        <th>User Name</th>
                        <th>Phone number</th>
                        <th>Delivery location</th>
                        <th>Change Role</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach(var user in @Model){
                    <tr>
                        <td><span class="user-id">@user.Id</span></td>
                            <td><span class="user-name">@user.fullName</span></td>
                            <td><span class="user-name">@user.userName</span></td>
                            <td><span class="user-name">@user.phoneNumber</span></td>
                            <td><span class="user-name">
                                    @if(user.deliveryLocation != null)
                                    {
                                        @user.deliveryLocation


                                    }



                            </span></td>

                        <td>
                            <form asp-action="Changeroles" asp-controller="Admin" method="post" class="role-form">
                                <input type="hidden" name="id" value="@user.Id" />
                                    <select name="role"
                                            class="role-select @user.role.ToString().ToLower()-select"
                                            onchange="this.form.submit()">

                                        @foreach (Role roleValue in Enum.GetValues<Role>())
                                        {
                                            if (user.role == roleValue)
                                            {
                                                <option value="@roleValue"  selected>
                                                    @roleValue
                                                </option>
                                            }
                                            else
                                            {
                                                <option value="@roleValue">
                                                    @roleValue
                                                </option>
                                            }
                                        }

                                    </select>
                            </form>
                        </td>
                        <td>
                            <div class="table-actions-group">
                                <a asp-action="ChangeUserPassword" asp-controller="Admin" asp-route-id="@user.Id" class="action-btn pass-btn">
                                    <i class="fa-solid fa-key"></i> Password
                                </a>
                                <form asp-action="DeleteUser" asp-controller="Admin" method="POST" onsubmit="return confirm('Are you sure you want to delete this user?');" class="inline-form">
                                    <input type="hidden" name="id" value="@user.Id">
                                    <button type="submit" class="action-btn delete-btn">
                                        <i class="fa-solid fa-trash-can"></i> Delete
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                    }
                 
                </tbody>
            </table>
        </div>

    </div>
</section>
