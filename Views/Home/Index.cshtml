
@{
    ViewData["Title"] = "Home";
}
@section Styles{
 <link rel="stylesheet" href="~/css/hero.css">
 <link rel="stylesheet" href="~/css/categories.css">
 <link rel="stylesheet" href="~/css/contact-section.css">
}

<section class="hero-section">
    <div class="hero-container">
        <div class="hero-content">
            <h1>Deliciousness Delivered to Your Door</h1>
            <p>Experience boutique dining from the comfort of your home. Fresh ingredients, artisan preparation, and rapid delivery.</p>
            
            <a href="/Home/Menu" class="hero-btn">
                View Menu <i class="fa-solid fa-arrow-right"></i>
            </a>
        </div>
    </div>
</section>


<section class="categories-section">
    <div class="categories-container">
        
        <span class="sub-title">BROWSE OUR FLAVORS</span>
        <h2 class="main-title">Popular Categories</h2>

        <div class="categories-grid">

            <div class="category-card" style="cursor:default;">
                <div class="category-icon-wrapper">
                    <i class="fa-solid fa-hamburger"></i>
                </div>
                <h3>Burgers</h3>
            </div>

            <div class="category-card" style="cursor:default;">
                <div class="category-icon-wrapper">
                    <i class="fa-solid fa-pizza-slice"></i>
                </div>
                <h3>Pizza</h3>
            </div>

            <div class="category-card" style="cursor:default;">
                <div class="category-icon-wrapper">
                    <i class="fa-solid fa-utensils"></i>
                </div>
                <h3>Pasta</h3>
            </div>

            <div class="category-card" style="cursor:default;">
                <div class="category-icon-wrapper">
                    <i class="fa-solid fa-glass-water"></i>
                </div>
                <h3>Drinks</h3>
            </div>

            </div>
    </div>
</section>

<link rel="stylesheet" href="~/css/about-section.css">

<section class="about-section">
    <div class="about-container">
        
        <div class="about-image-side">
            <div class="image-wrapper">
                <div class="deco-box"></div>
                <img src="https://lh3.googleusercontent.com/aida-public/AB6AXuCatK_D1IOjxrztVjTrX_WMi4TPVYCDcmf2BrFhxaV-0eSZnV9Wy7iz1qRZOzbpN2XHGXqKJ7tVEg51zRUVlbxQqENnVyacw8zzivqCar_oCQ_el-kqExqYwyT2EOnTKQHj14sX3hOJABGXmwfAGbWSXJ8KdHPbHc--SSd1TAL5WffU5tDE0dn83SS8lo22UU02bHBKhtgLIYqFCYGzTZbdOrV50d_1s6uOsJI1minOeKfNAYtSGjtrmxL6C74DGT17qDtBN8d2uyyP" alt="Our Chef Working" class="chef-img">
            </div>
        </div>

        <div class="about-text-side">
            <span class="sub-title">OUR STORY</span>
            <h2 class="main-title">Culinary Passion in Every Bite</h2>
            
            <p class="about-p">
                Born from a love of authentic flavors and the joy of shared meals, Restaurant Project brings the restaurant experience directly to your home. We partner with local farmers to source the freshest ingredients, ensuring every dish meets our uncompromising standards of quality.
            </p>
            
            <p class="about-p">
                Our team of dedicated chefs blends traditional techniques with modern innovation to create a menu that is as diverse as it is delicious. From hand-stretched pizzas to perfectly seared wagyu, we invite you to taste the difference.
            </p>

            <div class="stats-container">
                <div class="stat-box">
                    <h3>12k+</h3>
                    <p>HAPPY DINERS</p>
                </div>
                <div class="stat-box">
                    <h3>45+</h3>
                    <p>MASTER CHEFS</p>
                </div>
            </div>
        </div>

    </div>
</section>

<section class="contact-section">
    <div class="contact-card-container">
        
        <div class="contact-info-side">
            <h2>Get in Touch</h2>
            <p class="subtitle">Have a question or want to book a private event? We're here to help.</p>
            
            <div class="info-list">
                <div class="info-item">
                    <i class="fa-solid fa-location-dot"></i>
                    <div>
                        <strong>Visit Us</strong>
                        <p>AAUP GATE2 <br>JENIN</p>
                    </div>
                </div>
                
                <div class="info-item">
                    <i class="fa-solid fa-phone"></i>
                    <div>
                        <strong>Call Us</strong>
                        <p>0569549873</p>
                    </div>
                </div>
                
                <div class="info-item">
                    <i class="fa-solid fa-envelope"></i>
                    <div>
                        <strong>Email Us</strong>
                        <p>adelbassam5201@gmail.com</p>
                    </div>
                </div>
            </div>

        
        </div>

        <form action="" method="POST" class="contact-form-side">
            
            <div class="form-row">
                <div class="form-group">
                    <label for="full-name">Full Name</label>
                    <input type="text" id="full-name" name="full_name" placeholder="Adel Abualrub" required>
                </div>
                <div class="form-group">
                    <label for="email-address">Email Address</label>
                    <input type="email" id="email-address" name="email_address" placeholder="name@example.com" required>
                </div>
            </div>

            <div class="form-group">
                <label for="subject">Subject</label>
                <select id="subject" name="subject" required>
                    <option value="general" selected>General Inquiry</option>
                    <option value="booking">Book a Private Event</option>
                    <option value="complaint">Feedback / Complaint</option>
                </select>
            </div>

            <div class="form-group">
                <label for="message">Message</label>
                <textarea id="message" name="user_message" rows="4" placeholder="How can we help you?" required></textarea>
            </div>

            <button type="submit" class="send-message-btn">Send Message</button>
        </form>

    </div>
</section>



