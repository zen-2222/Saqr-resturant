@model PaymentModel
@{
    ViewData["Title"] = "Payment";

}

    @section Styles{
    <link rel="stylesheet" href="~/css/payment.css">
    }

<section class="payment-section">
    <div class="payment-container">
        
        <div class="payment-card">
            <div class="payment-header">
                <h2>Checkout & Payment</h2>
                <p>Enter your details and select a payment method to complete the order</p>
            </div>

            <form asp-action="Payment" asp-controller="Home" method="POST" class="payment-form">
                
                <div class="form-group">
                    <label asp-for="fullname">Full Name</label>
                    <input   asp-for="fullname" placeholder="Enter your full name" required>
                    <span style="color:red;font-size:.9em;" asp-validation-for="fullname"></span>
                </div>

                <div class="form-group">
                    <label aspfor="phonenumber">Phone Number</label>
                    <input type="tel" asp-for="phonenumber" placeholder="e.g. 059XXXXXXX" required>
                    <span style="color:red;font-size:.9em;" asp-validation-for="phonenumber"></span>

                </div>

                <div class="method-selector">
                    <label class="method-option">
                        <input type="radio" name="paymentmethod" value="0" checked onclick="toggleVisaForm(false)">
                        <div class="method-box">
                            <i class="fa-solid fa-money-bill-wave"></i>
                            <span>Cash on Delivery</span>
                        </div>
                    </label>

                    <label class="method-option">
                        <input type="radio" name="paymentmethod" value="1" onclick="toggleVisaForm(true)">
                        <div class="method-box">
                            <i class="fa-solid fa-credit-card"></i>
                            <span>Visa / Credit Card</span>
                        </div>
                    </label>
                </div>

                <div id="visa-details-form" class="visa-details-fields">
                    <div class="form-group">
                        <label asp-for="Cardholdername">Cardholder Name</label>
                        <input type="text" asp-for="Cardholdername" placeholder="John Doe" >
                        <span style="color:red;font-size:.9em;" asp-validation-for="Cardholdername"></span>

                    </div>

                    <div class="form-group">
                        <label asp-for="Cardnumber">Card Number</label>
                        <input type="text" asp-for="Cardnumber" placeholder="XXXX XXXX XXXX XXXX">
                        <span style="color:red;font-size:.9em;" asp-validation-for="Cardnumber"></span>

                    </div>

                    <div class="form-row">
                        <div class="form-group">
                            <label asp-for="expirydate">Expiry Date</label>
                            <input type="text" asp-for="expirydate" placeholder="MM/YY">
                            <span style="color:red;font-size:.9em;" asp-validation-for="expirydate"></span>

                        </div>
                        <div class="form-group">
                            <label asp-for="cvv">CVV</label>
                            <input type="text"asp-for="cvv" placeholder="XXX">
                            <span style="color:red;font-size:.9em;" asp-validation-for="cvv"></span>

                        </div>
                    </div>
                </div>

                <div class="form-group address-group">
                    <label asp-for="location">Delivery Address</label>
                    <textarea asp-for="location" rows="3" placeholder="Enter your full delivery address..." required></textarea>
                    <span style="color:red;font-size:.9em;" asp-validation-for="location"></span>

                </div>

                <button type="submit" class="place-order-btn">
                    <i class="fa-solid fa-circle-check"></i> Place Order ($@Model.total)
                </button>

            </form>
        </div>

    </div>
</section>

<script>
    function toggleVisaForm(show) {
        const visaForm = document.getElementById('visa-details-form');
        const visaInputs = visaForm.querySelectorAll('input');
        
        if (show) {
            visaForm.classList.add('active');
            visaInputs.forEach(input => input.setAttribute('required', 'true'));
        } else {
            visaForm.classList.remove('active');
            visaInputs.forEach(input => input.removeAttribute('required'));
        }
    }
</script>
